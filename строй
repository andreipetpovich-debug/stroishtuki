<style>
*{box-sizing:border-box;margin:0;padding:0;font-family:'Segoe UI',Arial,sans-serif}
:root{
  --green:#1a5c3a;
  --green-dark:#0f3d26;
  --green-light:#e8f5ee;
  --orange:#f5a623;
  --orange-dark:#d4891a;
  --gray-bg:#f4f5f6;
  --gray-text:#666;
  --border:#e0e0e0;
  --white:#fff;
  --text:#1a1a1a;
}
body{background:var(--gray-bg);color:var(--text);font-size:15px}

/* TOP BAR */
.top-bar{background:var(--green-dark);color:#cde8d8;padding:8px 40px;display:flex;justify-content:space-between;align-items:center;font-size:13px}
.top-bar a{color:#cde8d8;text-decoration:none;margin-left:14px;font-size:13px}
.top-bar a:hover{color:#fff}
.top-bar__left{display:flex;align-items:center;gap:16px}
.top-bar__right{display:flex;align-items:center}

/* HEADER */
.header{background:var(--white);padding:14px 40px;display:flex;align-items:center;gap:16px;border-bottom:1px solid var(--border)}
.logo{display:flex;align-items:center;gap:8px;text-decoration:none;min-width:200px}
.logo__icon{background:var(--orange);width:36px;height:36px;border-radius:7px;display:flex;align-items:center;justify-content:center}
.logo__icon svg{width:20px;height:20px;fill:white}
.logo__text{font-size:19px;font-weight:700;color:var(--green)}
.logo__text span{color:var(--orange)}
.logo__sub{font-size:11px;color:var(--gray-text);text-transform:uppercase;letter-spacing:1px}

.catalog-btn{background:var(--green);color:#fff;border:none;border-radius:7px;padding:11px 20px;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:8px;white-space:nowrap}
.catalog-btn:hover{background:var(--green-dark)}
.catalog-btn svg{width:16px;height:16px;fill:white}

.search-wrap{flex:1;display:flex;align-items:center;border:2px solid var(--green);border-radius:8px;overflow:hidden;height:44px}
.search-wrap input{flex:1;border:none;padding:0 16px;font-size:15px;outline:none;height:100%;color:var(--text)}
.search-select{border:none;border-left:1px solid var(--border);padding:0 12px;font-size:12px;color:var(--gray-text);background:var(--gray-bg);height:100%;outline:none;cursor:pointer}
.search-btn{background:var(--green);border:none;width:48px;height:100%;cursor:pointer;display:flex;align-items:center;justify-content:center}
.search-btn:hover{background:var(--green-dark)}
.search-btn svg{width:18px;height:18px;stroke:white;fill:none;stroke-width:2}

.header-icons{display:flex;align-items:center;gap:20px}
.icon-btn{display:flex;flex-direction:column;align-items:center;gap:2px;cursor:pointer;position:relative;color:var(--gray-text);text-decoration:none;font-size:13px}
.icon-btn svg{width:24px;height:24px;stroke:var(--green);fill:none;stroke-width:1.8}
.icon-btn:hover svg{stroke:var(--orange)}
.icon-btn:hover{color:var(--orange)}
.badge{position:absolute;top:-4px;right:-8px;background:var(--orange);color:#fff;font-size:9px;font-weight:700;width:17px;height:17px;border-radius:50%;display:flex;align-items:center;justify-content:center}

/* PROMO BAR */
.promo-bar{background:var(--orange);color:#fff;text-align:center;padding:11px 40px;font-size:15px;font-weight:600}
.promo-bar strong{font-size:15px}

/* NAV */
.nav-bar{background:var(--white);border-bottom:1px solid var(--border);padding:0 40px}
.nav-bar ul{display:flex;list-style:none}
.nav-bar li a{display:block;padding:13px 15px;font-size:14px;color:var(--text);text-decoration:none;border-bottom:2px solid transparent;transition:color .15s,border-color .15s}
.nav-bar li a:hover{color:var(--green);border-bottom-color:var(--green)}

/* HERO */
.hero{background:linear-gradient(120deg,var(--green-dark) 55%,var(--green) 100%);padding:48px 40px;display:flex;align-items:center;justify-content:space-between;gap:40px}
.hero__content{max-width:520px}
.hero__badge{background:var(--orange);color:#fff;font-size:13px;font-weight:700;padding:4px 14px;border-radius:20px;display:inline-block;margin-bottom:14px;letter-spacing:.5px;text-transform:uppercase}
.hero h1{color:#fff;font-size:28px;font-weight:700;line-height:1.3;margin-bottom:12px}
.hero h1 em{color:var(--orange);font-style:normal}
.hero p{color:#b8d9c6;font-size:15px;line-height:1.7;margin-bottom:22px}
.hero__btns{display:flex;gap:12px;flex-wrap:wrap}
.btn-primary{background:var(--orange);color:#fff;border:none;border-radius:7px;padding:13px 26px;font-size:13px;font-weight:700;cursor:pointer;transition:background .15s}
.btn-primary:hover{background:var(--orange-dark)}
.btn-outline{background:transparent;color:#fff;border:2px solid rgba(255,255,255,0.5);border-radius:7px;padding:13px 26px;font-size:13px;font-weight:600;cursor:pointer;transition:border-color .15s}
.btn-outline:hover{border-color:#fff}
.hero__stats{display:flex;gap:28px;margin-top:28px}
.stat{text-align:center}
.stat__num{color:var(--orange);font-size:26px;font-weight:700;line-height:1}
.stat__label{color:#8cb8a0;font-size:13px;margin-top:4px}
.hero__img{width:240px;min-width:200px;background:rgba(255,255,255,0.08);border-radius:14px;display:flex;align-items:center;justify-content:center;padding:28px;flex-direction:column;gap:14px}
.hero__img-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;width:100%}
.hero__img-cell{background:rgba(255,255,255,0.12);border-radius:10px;height:68px;display:flex;align-items:center;justify-content:center}
.hero__img-cell svg{width:30px;height:30px;stroke:#b8d9c6;fill:none;stroke-width:1.5}

/* ADVANTAGES */
.advantages{background:var(--white);padding:24px 40px;border-bottom:1px solid var(--border)}
.adv-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px}
.adv{display:flex;align-items:flex-start;gap:14px}
.adv__icon{background:var(--green-light);border-radius:10px;width:48px;height:48px;min-width:48px;display:flex;align-items:center;justify-content:center}
.adv__icon svg{width:24px;height:24px;stroke:var(--green);fill:none;stroke-width:1.8}
.adv h4{font-size:15px;font-weight:600;color:var(--text);margin-bottom:4px}
.adv p{font-size:13px;color:var(--gray-text);line-height:1.6}

/* SECTION */
.section{padding:28px 40px}
.section__head{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.section__title{font-size:17px;font-weight:700;color:var(--text)}
.section__link{font-size:12px;color:var(--green);text-decoration:none}
.section__link:hover{color:var(--orange)}

/* CATALOG GRID */
.cat-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:12px}
.cat-card{background:var(--white);border-radius:10px;border:1px solid var(--border);padding:16px 10px;text-align:center;cursor:pointer;transition:box-shadow .15s,border-color .15s;text-decoration:none;color:inherit;display:block}
.cat-card:hover{border-color:var(--green);box-shadow:0 3px 16px rgba(26,92,58,.12)}
.cat-card__icon{width:54px;height:54px;border-radius:12px;margin:0 auto 10px;display:flex;align-items:center;justify-content:center}
.cat-card__icon svg{width:30px;height:30px;fill:none;stroke-width:1.6}
.cat-card__name{font-size:14px;font-weight:600;color:var(--text);margin-bottom:3px}
.cat-card__count{font-size:13px;color:var(--gray-text)}

/* PRODUCT GRID */
.prod-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.prod-card{background:var(--white);border-radius:10px;border:1px solid var(--border);overflow:hidden;cursor:pointer;transition:box-shadow .15s}
.prod-card:hover{box-shadow:0 4px 20px rgba(0,0,0,.1)}
.prod-card__img{background:var(--gray-bg);height:150px;display:flex;align-items:center;justify-content:center;position:relative}
.prod-card__img svg{width:64px;height:64px;stroke:#aaa;fill:none;stroke-width:1.2}
.prod-card__badges{position:absolute;top:10px;left:10px;display:flex;gap:4px;flex-direction:column;align-items:flex-start}
.badge-hit{background:#e8f5ee;color:var(--green);font-size:9px;font-weight:700;padding:3px 8px;border-radius:4px}
.badge-new{background:#fff3e0;color:#e65100;font-size:9px;font-weight:700;padding:3px 8px;border-radius:4px}
.badge-sale{background:#fce4ec;color:#c62828;font-size:9px;font-weight:700;padding:3px 8px;border-radius:4px}
.prod-card__body{padding:12px 14px}
.prod-card__name{font-size:14px;font-weight:600;color:var(--text);margin-bottom:5px;line-height:1.4}
.prod-card__stock{font-size:13px;color:#2e7d32;margin-bottom:7px}
.prod-card__price{font-size:16px;font-weight:700;color:var(--green);margin-bottom:10px}
.prod-card__price span{font-size:13px;font-weight:400;color:var(--gray-text);text-decoration:line-through;margin-left:7px}
.prod-card__add{width:100%;background:var(--green);color:#fff;border:none;border-radius:7px;padding:9px;font-size:13px;font-weight:600;cursor:pointer;transition:background .15s}
.prod-card__add:hover{background:var(--green-dark)}

/* TAGS */
.tags-section{background:var(--white);padding:22px 40px;border-top:1px solid var(--border)}
.tags-title{font-size:14px;font-weight:700;color:var(--text);margin-bottom:14px}
.tags-wrap{display:flex;flex-wrap:wrap;gap:9px}
.tag{background:var(--green-light);color:var(--green);border-radius:20px;padding:8px 18px;font-size:13px;font-weight:600;cursor:pointer;border:1px solid rgba(26,92,58,.2);text-decoration:none;transition:background .15s,color .15s}
.tag:hover{background:var(--green);color:#fff}

/* FOOTER */
.footer{background:var(--green-dark);color:#8cb8a0;padding:36px 40px 18px}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:28px;margin-bottom:24px}
.footer-logo{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.footer-logo__icon{background:var(--orange);width:30px;height:30px;border-radius:7px;display:flex;align-items:center;justify-content:center}
.footer-logo__icon svg{width:16px;height:16px;fill:white}
.footer-logo__text{color:#fff;font-size:17px;font-weight:700}
.footer-logo__text span{color:var(--orange)}
.footer-desc{font-size:13px;line-height:1.8;color:#8cb8a0;margin-bottom:16px}
.footer-messengers{display:flex;gap:9px}
.messenger-btn{background:rgba(255,255,255,0.1);width:36px;height:36px;border-radius:9px;display:flex;align-items:center;justify-content:center;cursor:pointer;border:none;transition:background .15s}
.messenger-btn:hover{background:rgba(255,255,255,0.22)}
.messenger-btn svg{width:17px;height:17px;fill:#fff}
.footer-col h5{color:#fff;font-size:12px;font-weight:600;margin-bottom:12px}
.footer-col ul{list-style:none}
.footer-col ul li{margin-bottom:8px}
.footer-col ul li a{color:#8cb8a0;text-decoration:none;font-size:13px;transition:color .15s}
.footer-col ul li a:hover{color:#fff}
.footer-bottom{border-top:1px solid rgba(255,255,255,0.1);padding-top:16px;display:flex;justify-content:space-between;align-items:center;font-size:13px}
.footer-bottom a{color:#8cb8a0;text-decoration:none}
.footer-bottom a:hover{color:#fff}

/* RESPONSIVE */
@media(max-width:1100px){
  .cat-grid{grid-template-columns:repeat(3,1fr)}
  .prod-grid{grid-template-columns:repeat(2,1fr)}
  .adv-grid{grid-template-columns:repeat(2,1fr)}
  .footer-grid{grid-template-columns:1fr 1fr}
}
@media(max-width:768px){
  .top-bar__right{display:none}
  .header{flex-wrap:wrap;padding:12px 16px}
  .hero{flex-direction:column;padding:28px 16px}
  .hero__img{display:none}
  .hero__stats{gap:16px}
  .cat-grid{grid-template-columns:repeat(2,1fr)}
  .prod-grid{grid-template-columns:repeat(2,1fr)}
  .adv-grid{grid-template-columns:1fr}
  .footer-grid{grid-template-columns:1fr}
  .section,.advantages,.tags-section,.footer{padding-left:16px;padding-right:16px}
  .nav-bar{overflow-x:auto;padding:0 16px}
}
</style>
</head>
